APP_NAME=CEMS-MY
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cems_my
DB_USERNAME=cems_user
DB_PASSWORD=secure_password_here
DB_ROOT_PASSWORD=root_password_here

REDIS_HOST=redis
REDIS_PORT=6379

ENCRYPTION_KEY=your_32_char_encryption_key_here

# Rate API
EXCHANGE_RATE_API_KEY=your_api_key_here

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_DOMAIN=localhost

# Cache
CACHE_DRIVER=redis

# Queue
QUEUE_CONNECTION=redis
QUEUE_PREFIX=cems_queue_

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_PREFIX=cems_database_
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ====================
# BACKUP & RECOVERY
# ====================

# Backup Encryption (AES-256)
# Generate with: openssl rand -base64 32
BACKUP_ARCHIVE_PASSWORD=your_32_char_backup_encryption_key_here

# AWS S3 Configuration for Archive Storage
# Required for BNM 7-year compliance archive
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=cems-backup-archive

# Alternative: Use Laravel's existing S3 disk config
# BACKUP_S3_DISK=s3

# Backup Health Check Notifications
BACKUP_NOTIFICATION_EMAIL=admin@cems-my.local
BACKUP_SLACK_WEBHOOK_URL=

# Retention (days) - BNM Compliance
# Keep all backups: 7 days
# Keep daily backups: 30 days
# Keep weekly backups: 90 days
# Keep monthly backups: 84 months (7 years) for BNM compliance
BACKUP_RETENTION_MONTHLY_MONTHS=84
